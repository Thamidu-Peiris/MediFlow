PORT=8006
MONGODB_URI=mongodb://localhost:27017/mediflow

# Same secret as auth-service for JWT
JWT_SECRET=change_this_secret

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen` for local webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Forward to appointment service (no /api prefix — direct service port)
APPOINTMENT_SERVICE_URL=http://localhost:8004

# Public doctor list for slot validation (use http://doctor-service:8003 in Docker Compose)
DOCTOR_SERVICE_URL=http://localhost:8003

# Optional: service fee in LKR (whole rupees)
SERVICE_FEE_LKR=50

# Helakuru / HelaPay via PayHere (Sri Lanka)
# In PayHere → enable HelaPay so customers can pay with the Helakuru (HelaPay) wallet on checkout.
# https://www.payhere.lk/ — developer docs: https://developers.payhere.co/
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
# PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout

# Public URL PayHere can reach (use ngrok in dev)
API_PUBLIC_URL=http://localhost:8081
FRONTEND_URL=http://localhost:5173

# Dev only: allow POST /simulate-helapay in production if set to "true"
ALLOW_PAYMENT_SIMULATE=false

PORT=8005
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/mediflow-notification?retryWrites=true&w=majority

# Brevo SMTP (Email) — password is the SMTP key from Brevo dashboard
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-login@smtp-brevo.com
SMTP_PASSWORD=your-smtp-key
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=MediFlow Notifications

# Twilio (SMS). Trial accounts only reach "verified" destination numbers (Twilio Console).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Optional: national mobiles starting with 0 → E.164 (e.g. 94 → 077… becomes +9477…)
# SMS_DEFAULT_COUNTRY_CODE=94

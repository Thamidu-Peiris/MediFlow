PORT=8002
# Atlas: patient profile document (name, embedded report metadata, Cloudinary URLs). Report/avatar binaries are NOT stored here.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/mediflow-patient?retryWrites=true&w=majority
JWT_SECRET=change_this_secret

# Required for report & avatar files: Cloudinary stores the actual files. Patient-service does not save report bytes to MongoDB.
# Get keys from https://cloudinary.com/console
# Docker: put the same vars in this file (used by docker-compose) and rebuild after code changes.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Troubleshooting empty Cloudinary Media Library:
# - GET /api/patients/health → cloudinaryApiOk:true and cloudinaryCloudName must match the cloud name in the console.
# - If cloudinaryApiOk:false, keys are wrong or network blocked; upload errors will include the Cloudinary message.
# - Assets are under folder "mediflow/". Images in Media Library; PDFs/DICOM often under Assets → filter "Raw".
# - No quotes needed in .env; stray spaces are trimmed. If uploads still write /api/patients/uploads/... in MongoDB, rebuild patient-service (Docker or npm).

# Set to 1 for verbose upload/list logs, console step logs, and _uploadTrace in upload JSON responses.
# DEBUG_PATIENT_UPLOAD=1
#
# In development (NODE_ENV not production), upload responses also include _uploadTrace if the client sends:
#   X-MediFlow-Debug-Upload: 1
# The Vite dev app sends this automatically for report upload.

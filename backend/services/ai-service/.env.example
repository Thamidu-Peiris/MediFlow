# Save as: backend/services/ai-service/.env (next to this service's package.json).
# The server always loads this path — you can start Node from any working directory.

PORT=8008
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/mediflow-ai?retryWrites=true&w=majority

# ── Required for authenticated symptom analysis (same as auth-service) ──
JWT_SECRET=change_this_secret

# ── Google Gemini 3 (REQUIRED for symptom checker) ──────────────────────────
# Symptom analysis uses the Gemini API only. Create a key: https://aistudio.google.com/apikey
# Default targets Gemini 3 Flash preview; see https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_API_KEY=
# Override if needed (ListModels: GET .../v1beta/models?key=KEY)
GEMINI_MODEL=gemini-3-flash-preview

# Optional: outbound HTTP timeout for Gemini (ms), default 45000, max 120000
LLM_TIMEOUT_MS=45000
